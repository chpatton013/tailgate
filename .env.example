# Copy to .env and fill in TS_AUTHKEY. .env is gitignored (it holds a secret).
#
#   cp .env.example .env
#   ./bin/mint-authkey --write-env        # mints a key and fills TS_AUTHKEY for you
# or paste a key you minted in the Headplane UI:
#   TS_AUTHKEY=<paste here>

# --- required ---
# Pre-auth key for this node. Mint via ./bin/mint-authkey or the Headplane UI
# (https://headplane.example.com). Single-use is fine for a stable node with a
# persistent state volume.
TS_AUTHKEY=

# --- control plane (defaults match the headscale-infra tailnet) ---
TS_LOGIN_SERVER=https://headscale.example.com
TS_HOSTNAME=tailgate-laptop
TS_IMAGE_TAG=stable

# MagicDNS base domain for the tailnet (Tier 2: names the /etc/resolver split-DNS
# file). Must EXACTLY match your tailnet's MagicDNS base domain — this is the
# Headscale dns.base_domain, often under a *private* domain, not your public one.
# Nodes resolve as <name>.<domain>. Get it wrong and names fall through to public DNS.
TS_MAGICDNS_DOMAIN=ts.example.com

# Extra flags appended to `tailscale up`. e.g. --accept-routes to use the
# exit-node subnet routes, or --accept-dns=false to opt out of MagicDNS.
TS_UP_EXTRA_ARGS=

# --- host proxy ports (Tier 1) ---
TS_SOCKS5_PORT=1055
TS_HTTP_PROXY_PORT=1056

# --- mint-authkey settings (only needed if you use ./bin/mint-authkey) ---
# Headscale user the node registers under, and where the admin API key lives.
HEADSCALE_USER=user
HEADSCALE_ADMIN_KEY_SECRET=headscale/admin-api-key
# AWS_PROFILE=
# AWS_REGION=us-east-1
